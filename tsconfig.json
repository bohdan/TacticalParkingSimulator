{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "ES2020"],
    "strict": false,
    "noEmit": false,
    "noCheck": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "build",
    "moduleDetection": "force",
    "types": ["node"]
  },
  "include": [
    "game.ts",
    "editor.ts",
    "truck-physics-demo.ts",
    "**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build"
  ]
}
